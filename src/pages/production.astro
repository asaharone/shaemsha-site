---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const landscapeFilms = [
  { title: 'Fashion Film 2023', vimeoId: '787859901' },
  { title: 'Motion Graphics Reel', vimeoId: '767830687' },
];
const verticalFilms = [
  { title: 'Brand Film', vimeoId: '900449529' },
  { title: 'Brand Campaign 2024', vimeoId: '900446985' },
  { title: 'Wedding Campaign', vimeoId: '900404433' },
];
---

<BaseLayout title="Production — SHAEMSHA PRODUCTION">

  <!-- HERO with Showreel -->
  <section class="relative pt-20">
    <!-- Main Showreel 2023 -->
    <div class="max-w-6xl mx-auto px-6 pt-16">
      <div class="relative rounded-xl overflow-hidden" style="padding:56.25% 0 0 0;position:relative;">
        <iframe
          src="https://player.vimeo.com/video/796642146?title=0&byline=0&portrait=0&color=C4A265"
          style="position:absolute;top:0;left:0;width:100%;height:100%;"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title="SHOWREEL 2023 — SHAEMSHA PRODUCTION"
          loading="eager"
        ></iframe>
      </div>
    </div>

    <!-- Text below -->
    <div class="max-w-4xl mx-auto text-center py-16 px-6">
      <p class="text-xs tracking-[0.3em] uppercase text-accent font-mono mb-4">SHAEMSHA PRODUCTION</p>
      <h1 class="font-serif font-medium uppercase tracking-[3px] text-5xl md:text-7xl mb-4">EMILIA SHAKH</h1>
      <p class="text-text-muted mb-8">Director · Cinematographer · Editor</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#inquiry" class="bg-accent text-bg font-semibold px-8 py-4 text-sm tracking-wider uppercase hover:bg-accent-hover transition-all duration-300 rounded-lg">
          Leave a Request
        </a>
        <a href="https://t.me/shaemsha" target="_blank" rel="noopener noreferrer" class="border border-border text-text px-8 py-4 text-sm tracking-wider uppercase hover:border-accent hover:text-accent transition-all duration-300 rounded-lg">
          Contact Manager
        </a>
      </div>
    </div>
  </section>

  <!-- DIRECTOR'S STATEMENT -->
  <section class="py-24 px-6 border-t border-border fade-in">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">
      <div>
        <p class="font-serif italic text-2xl md:text-3xl text-accent/80 leading-relaxed">
          "I believe every brand has a story worth filming. My job is to find the visual language
          that makes it unforgettable."
        </p>
      </div>
      <div class="space-y-4 text-text-muted leading-relaxed">
        <p>
          My approach to direction is rooted in cinematic storytelling — creating visuals that feel
          like they belong on a screen, not a feed. Every project starts with understanding the emotion
          behind the brand.
        </p>
        <p>
          From concept to final cut, I oversee every stage of production — directing, shooting, editing,
          and motion graphics — to ensure the visual language stays consistent and the story lands with impact.
        </p>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS REEL -->
  <section class="py-24 px-6 fade-in">
    <div class="max-w-5xl mx-auto">
      <div class="flex justify-between items-end mb-8">
        <div>
          <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Highlights</p>
          <h2 class="font-serif text-xl md:text-2xl text-text font-medium">Selected Work</h2>
        </div>
        <a href="https://vimeo.com/user73530306" target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent-hover transition-colors">
          View on Vimeo →
        </a>
      </div>
      <div class="relative rounded-xl overflow-hidden" style="padding:56.25% 0 0 0;position:relative;">
        <iframe
          src="https://player.vimeo.com/video/703936443?title=0&byline=0&portrait=0&color=C4A265"
          style="position:absolute;top:0;left:0;width:100%;height:100%;"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title="HIGHLIGHTS — SHAEMSHA PRODUCTION"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FASHION FILMS — LANDSCAPE -->
  <section class="py-24 px-6 border-t border-border fade-in">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Fashion Films</p>
        <h2 class="font-serif text-xl md:text-2xl text-text font-medium">Commercial Work</h2>
        <p class="text-text-muted mt-3">All content — directing, shooting, editing — by Emilia Shakh</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {landscapeFilms.map(film => (
          <div class="group">
            <div class="relative rounded-lg overflow-hidden" style="padding:56.25% 0 0 0;position:relative;">
              <iframe
                src={`https://player.vimeo.com/video/${film.vimeoId}?title=0&byline=0&portrait=0&color=C4A265`}
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title={film.title}
                loading="lazy"
              ></iframe>
            </div>
            <p class="text-sm text-text-muted mt-3 text-center">{film.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VERTICAL FILMS — CAROUSEL -->
  <section class="py-16 fade-in">
    <div class="max-w-6xl mx-auto px-6 mb-8">
      <div class="flex justify-between items-end">
        <div>
          <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Vertical Content</p>
          <h2 class="font-serif text-xl md:text-2xl text-text font-medium">Mobile-First Films</h2>
        </div>
        <div class="hidden md:flex gap-2">
          <button id="prod-prev" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-muted hover:border-accent hover:text-accent transition-colors" aria-label="Previous">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="prod-next" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-muted hover:border-accent hover:text-accent transition-colors" aria-label="Next">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div id="prod-carousel" class="flex gap-4 md:gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth px-6 md:px-[calc((100vw-72rem)/2+1.5rem)] pb-4 prod-scrollbar">
      {verticalFilms.map(film => (
        <div class="flex-shrink-0 snap-center w-[220px] md:w-[260px]">
          <div class="phone-frame relative rounded-[24px] border-2 border-border/60 bg-black overflow-hidden shadow-xl shadow-black/20">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-20 h-5 bg-black rounded-b-xl z-10"></div>
            <div class="relative overflow-hidden" style="padding:177.5% 0 0 0;">
              <iframe
                src={`https://player.vimeo.com/video/${film.vimeoId}?title=0&byline=0&portrait=0&color=C4A265&background=1&muted=1`}
                style="position:absolute;top:-2%;left:-2%;width:104%;height:104%;"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title={film.title}
                loading="lazy"
              ></iframe>
            </div>
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="w-12 h-12 rounded-full bg-black/50 backdrop-blur-sm flex items-center justify-center">
                <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
          <p class="text-sm text-text-muted mt-4 text-center">{film.title}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-text-muted/40 text-xs mt-4 md:hidden">Swipe to browse</p>
  </section>

  <!-- SERVICES -->
  <section class="py-24 px-6 border-t border-border fade-in">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Services</p>
        <h2 class="font-serif text-xl md:text-2xl text-text font-medium">What I Offer</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: '🎬', title: 'Commercial Direction', desc: 'Brand films, product videos, campaign visuals' },
          { icon: '🎥', title: 'Brand Films', desc: 'Documentaries, storytelling, branded content' },
          { icon: '🎵', title: 'Music Videos', desc: 'Cinematic music video production' },
          { icon: '👗', title: 'Fashion Campaigns', desc: 'Editorial and commercial fashion production' },
          { icon: '🎨', title: 'Creative Direction', desc: 'Concept development and art direction' },
          { icon: '✨', title: 'Motion Graphics', desc: 'Animated titles, logos, and visual effects' },
        ].map(s => (
          <div class="p-6 border border-border rounded-xl bg-bg-card">
            <div class="text-2xl mb-3">{s.icon}</div>
            <h3 class="font-semibold mb-2">{s.title}</h3>
            <p class="text-sm text-text-muted">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-24 px-6 fade-in">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Process</p>
        <h2 class="font-serif text-xl md:text-2xl text-text font-medium">How We Work</h2>
      </div>
      <div class="grid md:grid-cols-5 gap-6">
        {[
          { step: '01', title: 'Brief', desc: 'Discovery call & understanding your vision' },
          { step: '02', title: 'Concept', desc: 'Creative treatment & visual direction' },
          { step: '03', title: 'Pre-Prod', desc: 'Planning, locations, talent, logistics' },
          { step: '04', title: 'Production', desc: 'Shoot day(s) with full crew' },
          { step: '05', title: 'Delivery', desc: 'Post-production, editing & final delivery' },
        ].map(p => (
          <div class="text-center">
            <div class="font-mono text-accent text-xs mb-2">{p.step}</div>
            <h3 class="font-semibold text-sm mb-1">{p.title}</h3>
            <p class="text-xs text-text-muted">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section class="py-24 px-6 border-t border-border fade-in" id="inquiry">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">Inquiries</p>
        <h2 class="font-serif text-xl md:text-2xl text-text font-medium">Start a Conversation</h2>
        <p class="text-text-muted mt-3">Tell me about your project and let's bring it to life.</p>
      </div>

      <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Name</label>
            <input type="text" name="name" required
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Company</label>
            <input type="text" name="company"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Email</label>
          <input type="email" name="email" required
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Project Type</label>
            <select name="type"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors">
              <option value="">Select...</option>
              <option>Commercial</option>
              <option>Brand Film</option>
              <option>Music Video</option>
              <option>Fashion Campaign</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Budget Range</label>
            <select name="budget"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors">
              <option value="">Select...</option>
              <option>€2,000 – €5,000</option>
              <option>€5,000 – €10,000</option>
              <option>€10,000 – €25,000</option>
              <option>€25,000+</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Project Brief</label>
          <textarea name="brief" rows="5"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors resize-none"
            placeholder="Tell me about your project, vision, and timeline..."></textarea>
        </div>

        <button type="submit"
          class="w-full bg-accent text-bg font-semibold py-4 rounded-lg text-sm tracking-wider uppercase hover:bg-accent-hover transition-colors">
          Send Brief
        </button>
      </form>
    </div>
  </section>

</BaseLayout>

<script src="https://player.vimeo.com/api/player.js"></script>

<script>
  const carousel = document.getElementById('prod-carousel');
  const prevBtn = document.getElementById('prod-prev');
  const nextBtn = document.getElementById('prod-next');
  if (carousel && prevBtn && nextBtn) {
    const scrollAmount = 280;
    prevBtn.addEventListener('click', () => carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' }));
  }
</script>

<style>
  .prod-scrollbar::-webkit-scrollbar { height: 2px; }
  .prod-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .prod-scrollbar::-webkit-scrollbar-thumb { background: rgba(196, 162, 101, 0.3); border-radius: 99px; }
  .prod-scrollbar { scrollbar-width: thin; scrollbar-color: rgba(196, 162, 101, 0.3) transparent; }
</style>
