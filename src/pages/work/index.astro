---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Work — Emilia Shaemsha">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-serif text-5xl md:text-7xl mb-6">Work</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        Selected projects across campaigns, hotels, UGC, and film production.
      </p>
      <p class="text-text-muted/50 text-sm mt-12">Portfolio coming soon.</p>
    </div>
  </section>
</BaseLayout>
