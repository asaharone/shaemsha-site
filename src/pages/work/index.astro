---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const videos = [
  { title: 'SHOWREEL 2023', vimeoId: '796642146', duration: '1:00', aspect: '56.25%', category: 'Showreel' },
  { title: 'HIGHLIGHTS', vimeoId: '703936443', duration: '1:37', aspect: '56.25%', category: 'Showreel' },
  { title: '25UNION Fashion Film 2023', vimeoId: '787859901', duration: '2:19', aspect: '56.25%', category: 'Fashion' },
  { title: '25UNION Brand Film', vimeoId: '900449529', duration: '0:39', aspect: '177.5%', category: 'Fashion' },
  { title: 'LU Brand 2024', vimeoId: '900446985', duration: '0:08', aspect: '177.5%', category: 'Fashion' },
  { title: '25UNION Fashion Video', vimeoId: '900410494', duration: '0:13', aspect: '177.5%', category: 'Fashion' },
  { title: 'ARI VILLOSO Wedding Brand', vimeoId: '900404433', duration: '0:35', aspect: '177.5%', category: 'Campaigns' },
  { title: 'Fashion Video for Angelann', vimeoId: '362290091', duration: '0:59', aspect: '56.25%', category: 'Fashion' },
  { title: 'Motion Graphics Reel', vimeoId: '767830687', duration: '0:19', aspect: '56.25%', category: 'Motion' },
];

const landscape = videos.filter(v => v.aspect === '56.25%');
const vertical = videos.filter(v => v.aspect === '177.5%');
---

<BaseLayout title="Work — Emilia Shaemsha">

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="font-serif text-5xl md:text-7xl mb-6">Work</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        Selected projects across fashion, campaigns, and production.
        All content — directing, shooting, editing — by Emilia Shakh.
      </p>
    </div>
  </section>

  <!-- LANDSCAPE VIDEOS -->
  <section class="py-12 px-6 fade-in">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        {landscape.map(v => (
          <div class="group">
            <div class="relative rounded-lg overflow-hidden" style={`padding:${v.aspect} 0 0 0;position:relative;`}>
              <iframe
                src={`https://player.vimeo.com/video/${v.vimeoId}?title=0&byline=0&portrait=0&color=C4A265`}
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title={v.title}
                loading="lazy"
              ></iframe>
            </div>
            <div class="flex justify-between items-center mt-3">
              <div>
                <h3 class="text-sm font-medium">{v.title}</h3>
                <span class="text-xs text-text-muted font-mono">{v.category}</span>
              </div>
              <span class="text-xs text-text-muted">{v.duration}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VERTICAL VIDEOS -->
  <section class="py-12 px-6 fade-in">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-2xl mb-8">Vertical / Mobile-First</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {vertical.map(v => (
          <div class="group">
            <div class="relative rounded-lg overflow-hidden max-w-[240px] mx-auto" style={`padding:${v.aspect} 0 0 0;position:relative;`}>
              <iframe
                src={`https://player.vimeo.com/video/${v.vimeoId}?title=0&byline=0&portrait=0&color=C4A265`}
                style="position:absolute;top:0;left:0;width:100%;height:100%;"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title={v.title}
                loading="lazy"
              ></iframe>
            </div>
            <div class="text-center mt-3">
              <h3 class="text-xs font-medium">{v.title}</h3>
              <span class="text-xs text-text-muted">{v.duration}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 text-center border-t border-border fade-in">
    <h2 class="font-serif text-3xl mb-6">Interested in working together?</h2>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`${base}collaborate/`} class="bg-accent text-bg font-semibold px-8 py-4 rounded-lg text-sm tracking-wider uppercase hover:bg-accent-hover transition-colors">
        For Brand Collaborations
      </a>
      <a href={`${base}production/`} class="border border-border text-text px-8 py-4 rounded-lg text-sm tracking-wider uppercase hover:border-accent hover:text-accent transition-colors">
        For Production Projects
      </a>
    </div>
  </section>

</BaseLayout>

<script src="https://player.vimeo.com/api/player.js"></script>
