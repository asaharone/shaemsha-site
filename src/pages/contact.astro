---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Emilia Shaemsha">

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <h1 class="font-serif text-5xl md:text-6xl mb-6">Get in Touch</h1>
      <p class="text-text-muted leading-relaxed">
        Whether you're a brand looking for content, a production company with a project,
        or just want to say hello — I'd love to hear from you.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <!-- Quick Links -->
      <div class="grid md:grid-cols-3 gap-4 mb-16">
        <a href="mailto:hello@shaemsha.com" class="p-6 bg-bg-card border border-border rounded-xl text-center hover:border-accent/40 transition-colors group">
          <div class="text-2xl mb-3">✉️</div>
          <div class="text-sm font-medium">Email</div>
          <div class="text-xs text-text-muted mt-1">hello@shaemsha.com</div>
        </a>
        <a href="https://instagram.com/shaemsha" target="_blank" class="p-6 bg-bg-card border border-border rounded-xl text-center hover:border-accent/40 transition-colors group">
          <div class="text-2xl mb-3">📸</div>
          <div class="text-sm font-medium">Instagram</div>
          <div class="text-xs text-text-muted mt-1">@shaemsha</div>
        </a>
        <div class="p-6 bg-bg-card border border-border rounded-xl text-center">
          <div class="text-2xl mb-3">📍</div>
          <div class="text-sm font-medium">Location</div>
          <div class="text-xs text-text-muted mt-1">Cyprus · Worldwide</div>
        </div>
      </div>

      <!-- Form -->
      <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Name</label>
            <input type="text" name="name" required
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Email</label>
            <input type="email" name="email" required
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Subject</label>
          <select name="subject"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors">
            <option value="">Select a topic...</option>
            <option>Brand Collaboration</option>
            <option>Production / Film Project</option>
            <option>Presets Question</option>
            <option>Press / Media</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Message</label>
          <textarea name="message" rows="5" required
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full bg-accent text-bg font-semibold py-4 rounded-lg text-sm tracking-wider uppercase hover:bg-accent-hover transition-colors">
          Send Message
        </button>
      </form>
    </div>
  </section>

</BaseLayout>
