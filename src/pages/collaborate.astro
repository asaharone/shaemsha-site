---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const services = [
  { name: 'UGC / Media Package', price: 'from €450', unit: 'per package', desc: 'Commercial visual content created for brand use across digital platforms. Includes edited imagery and short-form video content. Usage rights for paid ads discussed separately.', includes: ['4–6 edited photos', '1 short video up to 15–20s', 'Or 2 short raw-style clips', 'Organic brand use included'] },
  { name: 'IG Promo Story', price: '€150', unit: 'per story', desc: 'Instagram Story promotion with tag and link option. Photo or video format depending on the shoot result.' },
  { name: '3 Stories Package', price: '€380', unit: '3 stories', desc: 'A more organic story placement spread naturally within the page rhythm.' },
  { name: 'IG Promo Post / Carousel', price: 'from €850', unit: 'per post', desc: 'A permanent placement on the Instagram page. The final format and creative direction are shaped around the strongest shoot result.' },
  { name: 'IG Reel', price: 'from €1,100', unit: 'per reel', desc: 'A premium video placement created in line with the visual language of the page.' },
  { name: 'Hotel Collaboration', price: 'from €1,300', unit: '+ stay / custom', desc: 'Tailored collaboration package based on the stay, location and content scope. Usually includes 5 stories over one month + 1 main placement.', featured: true },
];

const faqs = [
  { q: 'How quickly do you respond?', a: 'I typically respond within 24–48 hours. For urgent requests, please mention this in your message.' },
  { q: "What's your content creation process?", a: 'After agreeing on the brief, I plan the shoot, create the content, edit, and deliver within the agreed timeline. You receive a selection of edited photos/videos for approval before posting.' },
  { q: 'Do you travel for collaborations?', a: "Yes! I'm currently based in Cyprus and travel frequently. Upcoming trips are listed on this page. Travel costs may apply depending on the location." },
  { q: 'What about usage rights for paid ads?', a: 'Organic brand use is included in all packages. Paid advertising usage rights (for running ads with my content) are discussed and priced separately.' },
  { q: 'Can I see more examples of your work?', a: 'Absolutely — visit my portfolio page or browse my Instagram @shaemsha for the latest content.' },
];
---

<BaseLayout title="Collaborate — Emilia Shaemsha">

  <!-- HERO -->
  <section class="relative pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-xs tracking-[0.2em] uppercase text-accent font-mono">For Brands & Agencies</span>
      <h1 class="font-serif text-5xl md:text-7xl mt-4 mb-6">Let's Create Together</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Brand campaigns · Hotel collaborations · UGC content
      </p>
    </div>
  </section>

  <!-- ABOUT AS CREATOR -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-4xl mx-auto grid md:grid-cols-[280px_1fr] gap-10 items-start">
      <div class="aspect-[3/4] rounded-lg overflow-hidden">
        <img src={`${base}images/hero.jpg`} alt="Emilia Shaemsha" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="font-serif text-2xl mb-4">About Me as a Creator</h2>
        <p class="text-text-muted leading-relaxed">
          Emilia is a videographer and photographer based in Cyprus, known for her cinematic, fashion-forward aesthetic.
          With a loyal audience of 97K+ on Instagram, she creates content that feels editorial yet authentic —
          blending lifestyle, travel, and fashion into a cohesive visual narrative that resonates with brands
          looking for premium, story-driven content.
        </p>
      </div>
    </div>
  </section>

  <!-- AUDIENCE STATS -->
  <section class="py-16 border-y border-border fade-in">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div class="p-6 bg-bg-card rounded-xl">
        <div class="font-serif text-3xl text-accent">97-99K</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Instagram Followers</div>
      </div>
      <div class="p-6 bg-bg-card rounded-xl">
        <div class="font-serif text-3xl text-accent">70%</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Women 18-34</div>
      </div>
      <div class="p-6 bg-bg-card rounded-xl">
        <div class="font-serif text-3xl text-accent">Top Geo</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">UA · CY · EU</div>
      </div>
      <div class="p-6 bg-bg-card rounded-xl">
        <div class="font-serif text-3xl text-accent">4.5%+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Avg Engagement</div>
      </div>
    </div>
  </section>

  <!-- SERVICES & PRICING -->
  <section class="py-24 px-6 fade-in">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl mb-4 text-center">Services & Pricing</h2>
      <p class="text-text-muted text-center mb-12 max-w-xl mx-auto">All rates are starting prices. Final pricing depends on scope, usage rights, and deliverables.</p>

      <div class="grid md:grid-cols-2 gap-4">
        {services.map(s => (
          <div class={`p-6 rounded-xl border transition-colors duration-300 ${s.featured ? 'border-accent/40 bg-accent/5' : 'border-border bg-bg-card hover:border-border/80'}`}>
            <div class="flex justify-between items-start gap-4 mb-3">
              <h3 class="font-semibold text-base">{s.name}</h3>
              <div class="text-right flex-shrink-0">
                <div class="text-xl font-bold text-accent">{s.price}</div>
                <div class="text-xs text-text-muted">{s.unit}</div>
              </div>
            </div>
            <p class="text-sm text-text-muted leading-relaxed">{s.desc}</p>
            {s.includes && (
              <ul class="mt-3 space-y-1">
                {s.includes.map(item => (
                  <li class="text-xs text-text-muted/80 flex items-center gap-2">
                    <span class="w-1 h-1 rounded-full bg-accent flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section class="py-24 px-6 border-t border-border fade-in" id="inquiry">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl mb-4 text-center">Send an Inquiry</h2>
      <p class="text-text-muted text-center mb-12">I'll get back to you within 48 hours.</p>

      <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Name</label>
            <input type="text" name="name" required
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Company / Brand</label>
            <input type="text" name="company"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Email</label>
          <input type="email" name="email" required
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Type of Collaboration</label>
            <select name="type"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors">
              <option value="">Select...</option>
              <option>UGC / Media Package</option>
              <option>IG Story</option>
              <option>IG Post / Carousel</option>
              <option>IG Reel</option>
              <option>Hotel Collaboration</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Budget Range</label>
            <select name="budget"
              class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors">
              <option value="">Select...</option>
              <option>€100 – €500</option>
              <option>€500 – €1,000</option>
              <option>€1,000 – €2,500</option>
              <option>€2,500+</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wider uppercase text-text-muted mb-2">Message</label>
          <textarea name="message" rows="4"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm text-text focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full bg-accent text-bg font-semibold py-4 rounded-lg text-sm tracking-wider uppercase hover:bg-accent-hover transition-colors">
          Send Inquiry
        </button>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 border-t border-border fade-in">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="group border border-border rounded-xl overflow-hidden">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer text-sm font-medium hover:bg-bg-card transition-colors">
              {faq.q}
              <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-45 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
