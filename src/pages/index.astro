---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const cards = [
  {
    href: `${base}ugc/`,
    title: 'UGC & PR',
    desc_en: 'Cinematic content, brand storytelling, and influencer collaborations',
    desc_ua: 'Кінематографічний контент, бренд-сторітелінг та колаборації з інфлюенсерами',
    image: `${base}images/hero.jpg`,
    cta: 'See Formats',
    span: false,
  },
  {
    href: `${base}production/`,
    title: 'Video Production',
    desc_en: 'Commercials, brand films, and fashion campaigns',
    desc_ua: 'Комерційне відео, бренд-фільми та fashion кампанії',
    image: `${base}images/hero.jpg`,
    cta: 'Learn More',
    span: false,
  },
  {
    href: `${base}presets/`,
    title: 'Presets',
    desc_en: 'Professional Lightroom presets for cinematic color grading',
    desc_ua: 'Професійні пресети для кінематографічної колірної обробки',
    image: `${base}images/hero.jpg`,
    cta: 'Shop Presets',
    span: true,
  },
];
---

<BaseLayout title="EMILIA SHAEMSHA — Videographer · Photographer · Director">

  <section class="pt-16 md:pt-20 px-2 md:px-4 pb-2 md:pb-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-1.5 md:gap-3">
      {cards.map(card => (
        <a
          href={card.href}
          class={`group relative overflow-hidden rounded-xl cursor-pointer ${
            card.span ? 'md:col-span-2 min-h-[28vh] md:min-h-[30vh]' : 'min-h-[30vh] md:min-h-[45vh]'
          }`}
        >
          <!-- B&W Background Image -->
          <img
            src={card.image}
            alt=""
            class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
            loading={card.span ? 'lazy' : 'eager'}
          />

          <!-- Dark Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/20" />

          <!-- Content -->
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-10">
            <h2 class="font-serif text-2xl md:text-4xl text-white tracking-[3px] mb-1.5 uppercase font-bold">
              {card.title}
            </h2>
            <p class="font-serif text-sm md:text-base text-white/90 italic font-medium mb-4 max-w-lg lang-desc">
              <span class="desc-ua">{card.desc_ua}</span>
              <span class="desc-en hidden">{card.desc_en}</span>
            </p>
            <span class="inline-block bg-accent text-bg px-8 py-3 text-xs font-bold tracking-[2px] uppercase rounded-lg group-hover:bg-accent-hover transition-all duration-300">
              {card.cta}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Language toggle sync
    function setLang(lang) {
      document.querySelectorAll('.desc-ua').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'ua');
      });
      document.querySelectorAll('.desc-en').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'en');
      });
      localStorage.setItem('shaemsha-lang', lang);
    }

    // Check saved language
    var saved = localStorage.getItem('shaemsha-lang') || 'ua';
    setLang(saved);

    // Listen for lang toggle events from nav
    window.addEventListener('lang-change', function(e) {
      setLang(e.detail);
    });
  });
</script>
