---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import IntroHero from '../../components/IntroHero.astro';
import UsageExample from '../../components/UsageExample.astro';
import {
  presets, pricing, checkoutUrls, faqItems, pageContent, usageExamplesOrder
} from '../../data/presets';

const defaultPreset = presets[0];
const pc = pageContent;

// Build ordered list of presets for Usage Examples section
const orderedPresets = usageExamplesOrder
  .map(id => presets.find(p => p.id === id))
  .filter((p): p is typeof presets[number] => p !== undefined);

// FAQ question translations (UA)
const faqQuestionsUa: Record<string, string> = {
  'Do these work on iPhone?': 'Чи працюють на iPhone?',
  'Can I use on Android?': 'Чи можу я використовувати на Android?',
  'How many photos can I edit?': 'Скільки фото я можу редагувати?',
  'Do I need the paid version of Lightroom?': 'Чи потрібна платна версія Lightroom?',
  'Can I get a refund?': 'Чи можу я отримати повернення коштів?',
  'Will I receive updates?': 'Чи отримаю я оновлення?',
};
---

<BaseLayout title="SHAEMSHA Presets 01 — Cinematic Lightroom Presets">

  <!-- 1. INTRO -->
  <IntroHero quote={pc.intro.quote} quoteUa={pc.intro.quoteUa} vimeoId={pc.intro.vimeoId} />

  <!-- 2. FIRST SCREEN: Everything needed for purchase -->
  <section class="pt-4 pb-8 md:pt-6 md:pb-12 px-4">
    <div class="max-w-[600px] md:max-w-5xl mx-auto">

      <!-- Desktop: two columns. Mobile: single column -->
      <div class="md:grid md:grid-cols-[1fr_380px] md:gap-8 md:items-start">

        <!-- LEFT: Photo + Strip -->
        <div>
          <!-- Main Before/After Photo -->
          <div id="main-photo">
            <BeforeAfter
              beforeImage={defaultPreset.beforeImage}
              afterImage={defaultPreset.afterImage}
              presetName={defaultPreset.name}
              autoPlay={true}
            />
          </div>

          <!-- Preset Strip -->
          <div class="flex gap-2 mt-3 overflow-x-auto pb-2 preset-scrollbar" id="preset-strip">
            {presets.map((preset, i) => (
              <button
                class={`preset-thumb flex-shrink-0 w-[52px] h-[68px] rounded-md overflow-hidden relative transition-opacity ${i === 0 ? 'opacity-100 outline outline-2 outline-offset-2 outline-accent' : 'opacity-50'}`}
                data-index={i}
                data-before={preset.beforeImage}
                data-after={preset.afterImage}
                data-name={preset.name}
                type="button"
                aria-label={`Preview ${preset.name}`}
              >
                <img src={preset.afterImage} alt={preset.name} class="w-full h-full object-cover" loading="lazy" />
                <span class="absolute bottom-1 left-0 right-0 text-center text-[8px] text-white font-medium tracking-wider drop-shadow-lg">{preset.name}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- RIGHT (desktop) / BELOW (mobile): Title + Buy -->
        <div class="md:sticky md:top-24">
          <!-- Header -->
          <div class="text-center md:text-left mb-4 mt-4 md:mt-0">
            <h1 class="font-serif font-medium tracking-[1px] text-xl md:text-2xl text-text">
              <span class="lang-ua">Shaemsha Lightroom Пресети — Пак <span class="font-sans">01</span></span>
              <span class="lang-en hidden">Shaemsha Lightroom Presets — Pack <span class="font-sans">01</span></span>
            </h1>
            <p class="text-text-muted text-xs mt-1">
              <span class="lang-ua">7 авторських пресетів для мобільного та десктопу</span>
              <span class="lang-en hidden">7 cinematic presets for mobile and desktop</span>
            </p>
          </div>

          <!-- "See usage examples" anchor link -->
          <a href="#usage-examples" class="block text-center md:text-left py-2 text-xs tracking-[1px] text-accent/70 hover:text-accent uppercase border-b border-white/5 mb-4 transition-colors">
            <span class="lang-ua">Дивитись приклади ↓</span>
            <span class="lang-en hidden">See usage examples ↓</span>
          </a>

      <!-- Currency Toggle + Price + Buy -->
      <div class="text-center mt-4">
        <div class="inline-flex gap-0.5 bg-bg-card rounded-full p-0.5 mb-3" id="currency-toggle">
          <button class="cur-btn px-4 py-1.5 rounded-full text-xs font-semibold transition-all bg-accent text-bg" data-currency="eur" type="button">EUR</button>
          <button class="cur-btn px-4 py-1.5 rounded-full text-xs font-semibold transition-all text-text-muted" data-currency="uah" type="button">UAH</button>
        </div>

        <div class="font-sans text-3xl text-accent" id="price-display">{pricing.eur.amount}</div>

        <a id="buy-button" href={checkoutUrls.eur} target="_blank"
           class="block mt-3 bg-accent text-bg font-bold py-4 rounded-xl text-xs tracking-[2px] uppercase hover:bg-accent-hover transition-colors">
          BUY NOW
        </a>

        <!-- Payment method icons -->
        <div class="flex justify-center items-center gap-3 mt-3" id="payment-icons-eur">
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="8" font-family="sans-serif" font-weight="600">VISA</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><circle cx="15" cy="12" r="7" fill="currentColor" opacity="0.3"/><circle cx="23" cy="12" r="7" fill="currentColor" opacity="0.2"/></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="6" font-family="sans-serif" font-weight="600">Apple Pay</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="5" font-family="sans-serif" font-weight="600">Google Pay</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="6" font-family="sans-serif" font-weight="600">PayPal</text></svg>
        </div>
        <div class="hidden justify-center items-center gap-3 mt-3" id="payment-icons-uah">
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="8" font-family="sans-serif" font-weight="600">VISA</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><circle cx="15" cy="12" r="7" fill="currentColor" opacity="0.3"/><circle cx="23" cy="12" r="7" fill="currentColor" opacity="0.2"/></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="6" font-family="sans-serif" font-weight="600">Apple Pay</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="5" font-family="sans-serif" font-weight="600">Google Pay</text></svg>
          <svg class="h-7 text-text-muted/50" viewBox="0 0 38 24" fill="currentColor"><rect width="38" height="24" rx="3" fill="currentColor" opacity="0.15"/><text x="19" y="15" text-anchor="middle" fill="currentColor" font-size="6" font-family="sans-serif" font-weight="600">mono</text></svg>
        </div>

        <!-- Trust badges -->
        <div class="flex justify-center gap-4 mt-3 text-xs text-text-muted">
          <span>
            <span class="lang-ua">✓ Миттєва доставка</span>
            <span class="lang-en hidden">✓ Instant email</span>
          </span>
          <span>✓ .dng + .xmp</span>
          <span>
            <span class="lang-ua">✓ Мобільний та десктоп</span>
            <span class="lang-en hidden">✓ Mobile & Desktop</span>
          </span>
        </div>

        </div><!-- /RIGHT column -->
      </div><!-- /grid -->
    </div>
  </section>

  <!-- 3. WHAT'S INCLUDED -->
  <section class="py-12 px-4 fade-in">
    <div class="max-w-[600px] mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-4">
        <span class="lang-ua">Що входить</span>
        <span class="lang-en hidden">What's Included</span>
      </h2>
      <div class="space-y-3">
        <div class="flex items-center gap-3 p-3 bg-bg-card rounded-lg">
          <span class="text-accent text-sm">✓</span>
          <div>
            <div class="text-sm text-text">
              <span class="lang-ua">7 пресетів для Lightroom</span>
              <span class="lang-en hidden">7 Lightroom Presets</span>
            </div>
            <div class="text-xs text-text-muted">.dng (Mobile) + .xmp (Desktop)</div>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 bg-bg-card rounded-lg">
          <span class="text-accent text-sm">✓</span>
          <div>
            <div class="text-sm text-text">
              <span class="lang-ua">Інструкція з встановлення</span>
              <span class="lang-en hidden">Installation Guide</span>
            </div>
            <div class="text-xs text-text-muted">
              <span class="lang-ua">Покрокова для мобільного та десктопу</span>
              <span class="lang-en hidden">Step-by-step for Mobile & Desktop</span>
            </div>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 bg-bg-card rounded-lg">
          <span class="text-accent text-sm">✓</span>
          <div>
            <div class="text-sm text-text">
              <span class="lang-ua">Миттєва доставка на email</span>
              <span class="lang-en hidden">Instant Email Delivery</span>
            </div>
            <div class="text-xs text-text-muted">
              <span class="lang-ua">Посилання для завантаження на вашу пошту</span>
              <span class="lang-en hidden">Download link sent to your email</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HOW IT WORKS -->
  <section class="py-16 px-4 fade-in">
    <div class="max-w-[480px] mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2 text-center">
        <span class="lang-ua">ЯК ЦЕ ПРАЦЮЄ</span>
        <span class="lang-en hidden">HOW IT WORKS</span>
      </h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium text-center mb-8">
        <span class="lang-ua">Від покупки до першого редагування за хвилини</span>
        <span class="lang-en hidden">From purchase to your first edit in minutes</span>
      </p>

      <!-- Steps list -->
      <div class="space-y-6">

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 flex-shrink-0 rounded-full border border-accent/40 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <div>
            <h3 class="text-base text-text font-medium mb-1">
              <span class="lang-ua">Легка оплата</span>
              <span class="lang-en hidden">Easy checkout</span>
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">Оплатіть картою в кілька натискань. Файли пресетів отримаєте на email миттєво.</span>
              <span class="lang-en hidden">Pay with card in a few taps. You'll receive the preset files to your email instantly.</span>
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 flex-shrink-0 rounded-full border border-accent/40 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </div>
          <div>
            <h3 class="text-base text-text font-medium mb-1">
              <span class="lang-ua">Отримайте файли</span>
              <span class="lang-en hidden">Get your files</span>
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">Завантажте .dng для Lightroom Mobile або .xmp для Desktop — обидва формати включені.</span>
              <span class="lang-en hidden">Download .dng for Lightroom Mobile or .xmp for Desktop — both formats included.</span>
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 flex-shrink-0 rounded-full border border-accent/40 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <h3 class="text-base text-text font-medium mb-1">
              <span class="lang-ua">Відкрийте Lightroom</span>
              <span class="lang-en hidden">Open Lightroom</span>
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">Безкоштовна версія Lightroom Mobile підходить ідеально — доступна на iOS та Android.</span>
              <span class="lang-en hidden">The free version of Lightroom Mobile works perfectly — available on iOS and Android.</span>
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 flex-shrink-0 rounded-full border border-accent/40 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m4-4l-4-4m0 0l-4 4m4-4V4"/></svg>
          </div>
          <div>
            <h3 class="text-base text-text font-medium mb-1">
              <span class="lang-ua">Імпортуйте та збережіть</span>
              <span class="lang-en hidden">Import & save as preset</span>
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">Відкрийте .dng &rarr; натисніть &bull;&bull;&bull; &rarr; &laquo;Create Preset&raquo; &rarr; назвіть. Один раз — і назавжди.</span>
              <span class="lang-en hidden">Open the .dng &rarr; tap &bull;&bull;&bull; &rarr; "Create Preset" &rarr; name it. Done once, stays forever.</span>
            </p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 flex-shrink-0 rounded-full border border-accent/40 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <div>
            <h3 class="text-base text-text font-medium mb-1">
              <span class="lang-ua">Зробіть своїм</span>
              <span class="lang-en hidden">Make it yours</span>
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">Застосуйте мій кінематографічний колір до своїх фото одним натисканням. Кожен кадр стає настроєм.</span>
              <span class="lang-en hidden">Apply my cinematic color to your own photos with one tap. Every frame becomes a feeling.</span>
            </p>
          </div>
        </div>

      </div>


    </div>
  </section>

  <!-- 6. USAGE EXAMPLES -->
  <section id="usage-examples" class="py-12 px-4 fade-in">
    <div class="max-w-[600px] mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">
          <span class="lang-ua">ПРИКЛАДИ ВИКОРИСТАННЯ</span>
          <span class="lang-en hidden">USAGE EXAMPLES</span>
        </h2>
        <h3 class="font-serif text-2xl md:text-3xl text-text">
          <span class="lang-ua">Де кожен пресет працює найкраще</span>
          <span class="lang-en hidden">Where each preset works best</span>
        </h3>
      </div>

      {orderedPresets.map(preset => (
        <UsageExample
          id={preset.id}
          name={preset.name}
          description={preset.description}
          descriptionUa={preset.descriptionUa}
          photos={preset.examplePhotos}
          beforePhotos={preset.exampleBeforePhotos}
          beforeImage={preset.beforeImage}
          afterImage={preset.afterImage}
        />
      ))}

      <!-- BUY NOW at end of Usage Examples -->
      <div class="mt-8 pt-8 text-center">
        <a id="buy-button-usage" href={checkoutUrls.eur} target="_blank"
           class="block bg-accent text-bg font-bold py-4 rounded-xl text-xs tracking-[2px] uppercase hover:bg-accent-hover transition-colors">
          BUY NOW — <span class="usage-price">{pricing.eur.amount}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="py-12 px-4 fade-in">
    <div class="max-w-[600px] mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">FAQ</h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium mb-6">
        <span class="lang-ua">Маєте питання? Ми маємо відповіді</span>
        <span class="lang-en hidden">Got questions? We've got answers</span>
      </p>
      <div class="space-y-2">
        {faqItems.map(item => (
          <details class="group border border-border rounded-lg overflow-hidden">
            <summary class="flex justify-between items-center px-4 py-3 cursor-pointer text-sm font-medium hover:bg-bg-card transition-colors">
              <span>
                <span class="lang-ua">{faqQuestionsUa[item.q] || item.q}</span>
                <span class="lang-en hidden">{item.q}</span>
              </span>
              <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-45 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-4 pb-3 text-sm text-text-muted leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    function setPageLang(lang) {
      document.querySelectorAll('.lang-ua').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'ua');
      });
      document.querySelectorAll('.lang-en').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'en');
      });
    }
    var saved = localStorage.getItem('shaemsha-lang') || 'ua';
    setPageLang(saved);
    window.addEventListener('lang-change', function(e) {
      setPageLang(e.detail);
    });
  });
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var strip = document.getElementById('preset-strip');
    var thumbs = strip ? strip.querySelectorAll('.preset-thumb') : [];
    var container = document.querySelector('#main-photo .ba-container');

    // --- Preset strip: switch main photo ---
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) {
          t.classList.remove('opacity-100', 'outline', 'outline-2', 'outline-offset-2', 'outline-accent');
          t.classList.add('opacity-50');
        });
        thumb.classList.remove('opacity-50');
        thumb.classList.add('opacity-100', 'outline', 'outline-2', 'outline-offset-2', 'outline-accent');

        if (container) {
          var beforeImg = container.querySelector('.ba-img-before');
          var afterImg = container.querySelector('.ba-img-after');
          var label = container.querySelector('.ba-container > div:first-of-type span');

          if (beforeImg) beforeImg.src = thumb.dataset.before;
          if (afterImg) afterImg.src = thumb.dataset.after;
          if (label) label.textContent = thumb.dataset.name;

          container.setAttribute('data-state', 'before');
        }
      });
    });

    // --- Currency toggle (updates both BUY NOW buttons) ---
    var curBtns = document.querySelectorAll('.cur-btn');
    var priceDisplay = document.getElementById('price-display');
    var buyBtn = document.getElementById('buy-button');
    var buyBtnUsage = document.getElementById('buy-button-usage');
    var usagePrice = document.querySelector('.usage-price');

    var priceData = {
      eur: { amount: '€15.90', url: buyBtn ? buyBtn.href : '#' },
      uah: { amount: '690₴', url: 'WORKER_URL/api/create-invoice' }
    };

    var iconsEur = document.getElementById('payment-icons-eur');
    var iconsUah = document.getElementById('payment-icons-uah');

    curBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cur = btn.dataset.currency;

        curBtns.forEach(function(b) {
          b.classList.remove('bg-accent', 'text-bg');
          b.classList.add('text-text-muted');
        });
        btn.classList.add('bg-accent', 'text-bg');
        btn.classList.remove('text-text-muted');

        if (priceDisplay) priceDisplay.textContent = priceData[cur].amount;
        if (buyBtn) buyBtn.href = priceData[cur].url;
        if (buyBtnUsage) buyBtnUsage.href = priceData[cur].url;
        if (usagePrice) usagePrice.textContent = priceData[cur].amount;

        // Switch payment icons
        if (iconsEur) iconsEur.classList.toggle('hidden', cur !== 'eur');
        if (iconsEur) iconsEur.classList.toggle('flex', cur === 'eur');
        if (iconsUah) iconsUah.classList.toggle('hidden', cur !== 'uah');
        if (iconsUah) iconsUah.classList.toggle('flex', cur === 'uah');
      });
    });
  });
</script>

