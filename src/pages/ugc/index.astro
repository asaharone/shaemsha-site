---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const services = [
  { name: 'UGC / Media Package', price: 'from €450', unit: 'per package', desc: 'Commercial visual content for brand use. Edited imagery and short-form video.', includes: ['4–6 edited photos', '1 short video up to 15–20s', 'Or 2 short raw-style clips', 'Organic brand use included'] },
  { name: 'IG Promo Story', price: '€150', unit: 'per story', desc: 'Instagram Story promotion with tag and link option.' },
  { name: '3 Stories Package', price: '€380', unit: '3 stories', desc: 'Organic story placement spread naturally within the page rhythm.' },
  { name: 'IG Promo Post / Carousel', price: 'from €850', unit: 'per post', desc: 'Permanent placement on Instagram. Creative direction shaped around strongest shoot result.' },
  { name: 'IG Reel', price: 'from €1,100', unit: 'per reel', desc: 'Premium video placement in line with the visual language of the page.' },
  { name: 'Hotel Collaboration', price: 'from €1,300', unit: '+ stay', desc: 'Tailored package based on stay, location and content scope. Usually includes 5 stories + 1 main placement.', featured: true },
];

const faqs = [
  { q: 'How quickly do you respond?', a: 'I typically respond within 24–48 hours. For urgent requests, please mention this in your message.' },
  { q: "What's your content creation process?", a: 'After agreeing on the brief, I plan the shoot, create the content, edit, and deliver within the agreed timeline.' },
  { q: 'Do you travel for collaborations?', a: "Yes! I'm based in Cyprus and travel frequently. Travel costs may apply depending on the location." },
  { q: 'What about usage rights for paid ads?', a: 'Organic brand use is included. Paid advertising rights are discussed and priced separately.' },
];
---

<BaseLayout title="UGC & PR — Emilia Shaemsha">

  <!-- HERO -->
  <section class="relative pt-20">
    <div class="max-w-6xl mx-auto px-6 pt-8">
      <div class="aspect-[21/9] rounded-xl overflow-hidden">
        <img src={`${base}images/hero.jpg`} alt="UGC and Content Creation" class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="max-w-4xl mx-auto text-center py-12 px-6">
      <span class="text-xs tracking-[0.2em] uppercase text-accent font-mono">UGC & PR</span>
      <h1 class="font-serif font-medium text-4xl md:text-6xl mt-4 mb-6 uppercase tracking-[3px]">Content Creation</h1>
      <p class="text-text-muted text-base max-w-2xl mx-auto leading-relaxed">
        Cinematic content, brand storytelling, and influencer collaborations.
        Professional-grade UGC shot on cinema cameras with editorial post-production.
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-12 border-y border-border fade-in">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">97K+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Followers</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">70%</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Women 18-34</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">UA · CY · EU</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Top Geo</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">4.5%+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Engagement</div>
      </div>
    </div>
  </section>

  <!-- SERVICES & PRICING -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2 text-center">Services & Pricing</h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium text-center mb-10">Formats that work for your brand</p>

      <div class="grid md:grid-cols-2 gap-4">
        {services.map(s => (
          <div class={`p-6 rounded-xl border transition-colors duration-300 ${s.featured ? 'border-accent/40 bg-accent/5' : 'border-border bg-bg-card hover:border-border/80'}`}>
            <div class="flex justify-between items-start gap-4 mb-3">
              <h3 class="font-medium text-base">{s.name}</h3>
              <div class="text-right flex-shrink-0">
                <div class="text-lg font-bold text-accent">{s.price}</div>
                <div class="text-xs text-text-muted">{s.unit}</div>
              </div>
            </div>
            <p class="text-sm text-text-muted leading-relaxed">{s.desc}</p>
            {s.includes && (
              <ul class="mt-3 space-y-1">
                {s.includes.map(item => (
                  <li class="text-xs text-text-muted/80 flex items-center gap-2">
                    <span class="w-1 h-1 rounded-full bg-accent flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>

      <p class="text-xs text-text-muted text-center mt-6">All rates are starting prices. Final pricing depends on scope, usage rights, and deliverables.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-2xl md:text-3xl font-medium mb-4">Ready to create?</h2>
      <p class="text-text-muted mb-8">Get in touch to discuss your project</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://t.me/shaemsha" target="_blank" rel="noopener noreferrer"
           class="bg-accent text-bg font-bold px-8 py-4 text-xs tracking-[2px] uppercase hover:bg-accent-hover transition-colors rounded-lg cursor-pointer">
          Contact via Telegram
        </a>
        <a href="https://instagram.com/shaemsha" target="_blank" rel="noopener noreferrer"
           class="border border-border text-text px-8 py-4 text-xs tracking-[2px] uppercase hover:border-accent hover:text-accent transition-colors rounded-lg cursor-pointer">
          View Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">FAQ</h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium mb-6">Common questions</p>
      <div class="space-y-2">
        {faqs.map(faq => (
          <details class="group border border-border rounded-lg overflow-hidden">
            <summary class="flex justify-between items-center px-4 py-3 cursor-pointer text-sm font-medium hover:bg-bg-card transition-colors">
              {faq.q}
              <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-45 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-4 pb-3 text-sm text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
