---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const services = [
  {
    name: 'UGC / Media Content',
    price: 'from €200',
    unit: 'per look',
    desc_en: 'Visual content created for brand use only — aesthetic imagery and short-form video, without personal posting.',
    desc_ua: 'Фото- та відеоконтент для бренду без публікації в моєму профілі.',
  },
  {
    name: 'IG Promo Story',
    name_ua: 'IG Promo Stories',
    price: '€150',
    unit: 'per story',
    desc_en: 'Instagram Story promotion with brand tag and optional link.',
    desc_ua: 'Рекламне розміщення в Instagram Stories з відміткою бренду та можливістю додати посилання.',
  },
  {
    name: '3 Stories Package',
    price: '€380',
    unit: '3 stories',
    desc_en: 'A set of 3 Stories integrated naturally into the page flow.',
    desc_ua: 'Серія з 3 Stories, органічно інтегрована у візуальну подачу сторінки.',
  },
  {
    name: 'IG Promo Post / Carousel',
    price: 'from €750',
    unit: 'per post',
    desc_en: 'Permanent Instagram placement with creative tailored to the strongest visual outcome.',
    desc_ua: 'Пост або карусель у feed з найкращими кадрами у стилі сторінки.',
  },
  {
    name: 'IG Reel',
    price: 'from €900',
    unit: 'per reel',
    desc_en: 'Premium Reel placement aligned with the visual language of the page.',
    desc_ua: 'Reel у візуальній подачі сторінки.',
  },
  {
    name: 'Hotel Collaboration',
    price: 'from €1,000',
    unit: '+ stay',
    desc_en: 'Tailored package based on stay, location, and content scope. Usually includes 5 Stories and 1 main placement.',
    desc_ua: 'Індивідуальний формат співпраці залежно від локації, умов проживання та обсягу контенту.',
    featured: true,
  },
];

const faqs = [
  { q: 'How quickly do you respond?', a: 'I typically respond within 24–48 hours. For urgent requests, please mention this in your message.' },
  { q: "What's your content creation process?", a: 'After agreeing on the brief, I plan the shoot, create the content, edit, and deliver within the agreed timeline.' },
  { q: 'Do you travel for collaborations?', a: "Yes! I'm based in Cyprus and travel frequently. Travel costs may apply depending on the location." },
  { q: 'What about usage rights for paid ads?', a: 'Organic brand use is included. Paid advertising rights are discussed and priced separately.' },
];
---

<BaseLayout title="UGC & PR — Emilia Shaemsha">

  <!-- HERO -->
  <section class="relative pt-20">
    <div class="max-w-6xl mx-auto px-6 pt-8">
      <div class="aspect-[21/9] rounded-xl overflow-hidden">
        <img src={`${base}images/hero.jpg`} alt="UGC and Content Creation" class="w-full h-full object-cover" />
      </div>
    </div>

    <div class="max-w-4xl mx-auto text-center py-12 px-6">
      <span class="text-xs tracking-[0.2em] uppercase text-accent font-mono">UGC & PR</span>
      <h1 class="font-serif font-medium text-4xl md:text-6xl mt-4 mb-6 uppercase tracking-[3px]">Content Creation</h1>
      <p class="text-text-muted text-base max-w-2xl mx-auto leading-relaxed">
        <span class="lang-ua">
          Shaemsha створює естетичний контент для брендів та кампаній — від UGC і lifestyle-відео до кінематографічних візуалів із делікатною подачею продукту. У центрі — атмосфера, візуальна мова бренду та контент, що органічно поєднує естетику, сторітелінг і комерційну цінність.
        </span>
        <span class="lang-en hidden">
          Shaemsha creates aesthetic content for brands and campaigns — from UGC and lifestyle videos to cinematic visuals with a refined product presentation. At the core are atmosphere, the brand's visual language, and content that naturally blends aesthetics, storytelling, and commercial value.
        </span>
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-12 border-y border-border fade-in">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">95K+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Followers</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">70%</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Women 18-34</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-2xl text-accent">Ukraine · Europe</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Top Geo</div>
      </div>
      <div class="p-4 bg-bg-card rounded-xl">
        <div class="font-serif text-lg md:text-xl text-accent">Fashion · Beauty · Lifestyle</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-1">Brand Fit</div>
      </div>
    </div>
  </section>

  <!-- SERVICES & PRICING -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2 text-center">Services & Pricing</h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium text-center mb-10">Formats that work for your brand</p>

      <div class="grid md:grid-cols-2 gap-4">
        {services.map(s => (
          <div class={`p-6 rounded-xl border transition-colors duration-300 ${s.featured ? 'border-accent/40 bg-accent/5' : 'border-border bg-bg-card hover:border-border/80'}`}>
            <div class="flex justify-between items-start gap-4 mb-3">
              <h3 class="font-medium text-base">
                <span class="lang-ua">{s.name_ua || s.name}</span>
                <span class="lang-en hidden">{s.name}</span>
              </h3>
              <div class="text-right flex-shrink-0">
                <div class="text-lg font-bold text-accent">{s.price}</div>
                <div class="text-xs text-text-muted">{s.unit}</div>
              </div>
            </div>
            <p class="text-sm text-text-muted leading-relaxed">
              <span class="lang-ua">{s.desc_ua}</span>
              <span class="lang-en hidden">{s.desc_en}</span>
            </p>
          </div>
        ))}
      </div>

      <p class="text-xs text-text-muted text-center mt-6">
        <span class="lang-ua">Усі ціни є стартовими. Фінальна вартість залежить від обсягу роботи, прав використання та кількості матеріалів.</span>
        <span class="lang-en hidden">All rates are starting prices. Final pricing depends on scope, usage rights, and deliverables.</span>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-2xl md:text-3xl font-medium mb-4">Ready to create?</h2>
      <p class="text-text-muted mb-8">Get in touch to discuss your project</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://t.me/shaemsha" target="_blank" rel="noopener noreferrer"
           class="bg-accent text-bg font-bold px-8 py-4 text-xs tracking-[2px] uppercase hover:bg-accent-hover transition-colors rounded-lg cursor-pointer">
          Contact via Telegram
        </a>
        <a href="https://instagram.com/shaemsha" target="_blank" rel="noopener noreferrer"
           class="border border-border text-text px-8 py-4 text-xs tracking-[2px] uppercase hover:border-accent hover:text-accent transition-colors rounded-lg cursor-pointer">
          View Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-accent text-xs tracking-[2px] uppercase font-mono mb-2">FAQ</h2>
      <p class="font-serif text-xl md:text-2xl text-text font-medium mb-6">Common questions</p>
      <div class="space-y-2">
        {faqs.map(faq => (
          <details class="group border border-border rounded-lg overflow-hidden">
            <summary class="flex justify-between items-center px-4 py-3 cursor-pointer text-sm font-medium hover:bg-bg-card transition-colors">
              {faq.q}
              <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-45 flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-4 pb-3 text-sm text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    function setLang(lang) {
      document.querySelectorAll('.lang-ua').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'ua');
      });
      document.querySelectorAll('.lang-en').forEach(function(el) {
        el.classList.toggle('hidden', lang !== 'en');
      });
      localStorage.setItem('shaemsha-lang', lang);
    }
    var saved = localStorage.getItem('shaemsha-lang') || 'ua';
    setLang(saved);
    window.addEventListener('lang-change', function(e) {
      setLang(e.detail);
    });
  });
</script>
