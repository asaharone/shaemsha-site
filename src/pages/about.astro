---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Emilia Shaemsha">

  <!-- HERO IMAGE -->
  <section class="pt-20">
    <div class="max-w-7xl mx-auto px-6 pt-16">
      <div class="aspect-[21/9] rounded-xl overflow-hidden">
        <img src={`${base}images/hero.jpg`} alt="Emilia at work" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- BIO -->
  <section class="py-24 px-6 fade-in">
    <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_2fr] gap-12">
      <div>
        <h1 class="font-serif text-4xl md:text-5xl leading-tight">Emilia<br />Shakh</h1>
        <p class="text-text-muted text-sm mt-3 tracking-wide">aka SHAEMSHA</p>
      </div>
      <div class="space-y-5 text-text-muted leading-relaxed">
        <p>
          Ukrainian-born videographer, photographer, and director based in Cyprus. With a background
          that spans from Miss Ukraine World 2017 to professional filmmaking, I bring a cinematic eye
          to brand campaigns, fashion editorials, and UGC production.
        </p>
        <p>
          With 97K+ followers on Instagram and over 150 brand campaigns across 7+ countries, I work
          at the intersection of beauty, storytelling, and commercial video production.
        </p>
        <p>
          My production studio, SHAEMSHA PRODUCTION, handles everything from directing and shooting
          to editing and motion graphics. I believe the best brand content doesn't look like advertising —
          it feels like a story worth watching.
        </p>
        <p>
          When I'm not behind the camera, I create cinematic Lightroom presets that help other
          creators achieve the look and feel of professional color grading.
        </p>
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="py-16 border-y border-border fade-in">
    <div class="max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="font-serif text-4xl text-accent">7+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Years in Visual Storytelling</div>
      </div>
      <div>
        <div class="font-serif text-4xl text-accent">97K+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Instagram Community</div>
      </div>
      <div>
        <div class="font-serif text-4xl text-accent">150+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Brand Campaigns</div>
      </div>
      <div>
        <div class="font-serif text-4xl text-accent">7+</div>
        <div class="text-xs tracking-wider uppercase text-text-muted mt-2">Countries Shot In</div>
      </div>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-xs tracking-[0.2em] uppercase text-text-muted mb-6">Brands & Clients</p>
      <p class="font-serif text-xl md:text-2xl text-text/70 tracking-wide">
        25UNION · LU · ARI VILLOSO · Angelann
      </p>
    </div>
  </section>

  <!-- WHAT I DO -->
  <section class="py-24 px-6 border-t border-border fade-in">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl text-center mb-12">What I Do</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <a href={`${base}collaborate/`} class="group p-8 border border-border rounded-xl text-center hover:border-accent/40 hover:bg-accent/5 transition-all duration-300">
          <h3 class="font-semibold mb-2">Brand Collaborations</h3>
          <p class="text-sm text-text-muted">Campaigns, UGC, hotel partnerships</p>
          <span class="inline-block mt-4 text-accent text-sm opacity-0 group-hover:opacity-100 transition-opacity">Learn more →</span>
        </a>
        <a href={`${base}shop/`} class="group p-8 border border-border rounded-xl text-center hover:border-accent/40 hover:bg-accent/5 transition-all duration-300">
          <h3 class="font-semibold mb-2">Cinematic Presets</h3>
          <p class="text-sm text-text-muted">Professional Lightroom presets</p>
          <span class="inline-block mt-4 text-accent text-sm opacity-0 group-hover:opacity-100 transition-opacity">Shop now →</span>
        </a>
        <a href={`${base}production/`} class="group p-8 border border-border rounded-xl text-center hover:border-accent/40 hover:bg-accent/5 transition-all duration-300">
          <h3 class="font-semibold mb-2">Production & Direction</h3>
          <p class="text-sm text-text-muted">Commercials, brand films, fashion campaigns</p>
          <span class="inline-block mt-4 text-accent text-sm opacity-0 group-hover:opacity-100 transition-opacity">View reel →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CURRENTLY -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-3xl mx-auto bg-bg-card border border-border rounded-xl p-8">
      <div class="grid md:grid-cols-3 gap-6 text-center">
        <div>
          <div class="text-xs tracking-wider uppercase text-text-muted mb-2">Based In</div>
          <div class="font-medium">Cyprus</div>
        </div>
        <div>
          <div class="text-xs tracking-wider uppercase text-text-muted mb-2">Upcoming</div>
          <div class="font-medium">Bali</div>
        </div>
        <div>
          <div class="text-xs tracking-wider uppercase text-text-muted mb-2">Open For</div>
          <div class="font-medium text-sm">Campaigns · Production · Worldwide</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL LINKS -->
  <section class="py-16 px-6 fade-in">
    <div class="max-w-3xl mx-auto">
      <h3 class="font-serif text-2xl text-center mb-8">Connect</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="https://instagram.com/shaemsha" target="_blank" class="p-4 border border-border rounded-xl text-center hover:border-accent/40 transition-colors">
          <div class="text-sm font-medium">Instagram</div>
          <div class="text-xs text-text-muted mt-1">@shaemsha</div>
        </a>
        <a href="https://instagram.com/shaemshavideo" target="_blank" class="p-4 border border-border rounded-xl text-center hover:border-accent/40 transition-colors">
          <div class="text-sm font-medium">IG Video</div>
          <div class="text-xs text-text-muted mt-1">@shaemshavideo</div>
        </a>
        <a href="https://vimeo.com/user73530306" target="_blank" class="p-4 border border-border rounded-xl text-center hover:border-accent/40 transition-colors">
          <div class="text-sm font-medium">Vimeo</div>
          <div class="text-xs text-text-muted mt-1">SHAEMSHA</div>
        </a>
        <a href="mailto:hello@shaemsha.com" class="p-4 border border-border rounded-xl text-center hover:border-accent/40 transition-colors">
          <div class="text-sm font-medium">Email</div>
          <div class="text-xs text-text-muted mt-1">hello@shaemsha.com</div>
        </a>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="py-24 px-6 text-center border-t border-border fade-in">
    <h2 class="font-serif text-4xl mb-6">Let's Work Together</h2>
    <p class="text-text-muted mb-8 max-w-md mx-auto">Have a project in mind? I'd love to hear about it.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="mailto:hello@shaemsha.com" class="bg-accent text-bg font-semibold px-8 py-4 rounded-lg text-sm tracking-wider uppercase hover:bg-accent-hover transition-colors">
        Email Me
      </a>
      <a href="https://instagram.com/shaemsha" target="_blank" class="border border-border text-text px-8 py-4 rounded-lg text-sm tracking-wider uppercase hover:border-accent hover:text-accent transition-colors">
        Instagram DM
      </a>
    </div>
  </section>

</BaseLayout>
