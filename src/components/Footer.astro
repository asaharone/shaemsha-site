---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const links = [
  { href: `${base}work/`, label: 'Work' },
  { href: `${base}collaborate/`, label: 'Collaborate' },
  { href: `${base}shop/`, label: 'Presets' },
  { href: `${base}production/`, label: 'Production' },
  { href: `${base}about/`, label: 'About' },
  { href: `${base}contact/`, label: 'Contact' },
];
---

<footer class="border-t border-border mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href={base} class="font-serif text-lg tracking-[0.2em] text-text uppercase font-semibold">
          SHAEMSHA
        </a>
        <p class="text-text-muted text-sm mt-3 leading-relaxed">
          Videographer · Photographer · Director<br />
          Cyprus — Available Worldwide
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-text-muted mb-4">Navigation</h4>
        <div class="grid grid-cols-2 gap-2">
          {links.map(link => (
            <a href={link.href} class="text-sm text-text-muted hover:text-accent transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-text-muted mb-4">Connect</h4>
        <div class="flex flex-col gap-2">
          <a href="https://instagram.com/shaemsha" target="_blank" class="text-sm text-text-muted hover:text-accent transition-colors">
            Instagram @shaemsha
          </a>
          <a href="https://instagram.com/shaemshavideo" target="_blank" class="text-sm text-text-muted hover:text-accent transition-colors">
            IG Video @shaemshavideo
          </a>
          <a href="https://vimeo.com/user73530306" target="_blank" class="text-sm text-text-muted hover:text-accent transition-colors">
            Vimeo
          </a>
          <a href="mailto:hello@shaemsha.com" class="text-sm text-text-muted hover:text-accent transition-colors">
            hello@shaemsha.com
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border text-center text-text-muted text-xs">
      &copy; {year} Emilia Shaemsha. All rights reserved.
    </div>
  </div>
</footer>
